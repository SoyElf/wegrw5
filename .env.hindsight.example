# Hindsight Configuration - Gemini/Google AI Studio Setup

# Required: Google AI Studio API Key
# Get your key from: https://aistudio.google.com/app/apikeys
HINDSIGHT_API_LLM_API_KEY=your-google-ai-studio-api-key-here

# Optional: LLM Provider
# Supported: openai, anthropic, gemini, groq, ollama, lmstudio, minimax
HINDSIGHT_API_LLM_PROVIDER=gemini

# Optional: Specific model variant (if provider supports multiple models)
HINDSIGHT_API_LLM_MODEL=gemini-2.5-flash

# Optional: Database persistence location
# Default: $HOME/.hindsight-docker
# HINDSIGHT_DATABASE_PATH=$HOME/.hindsight-docker
